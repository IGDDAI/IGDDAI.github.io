<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>IGDD-AI | Intelligent Inspection Solutions for Manufacturing</title>
    <meta
      name="description"
      content="IGDD-AI is an IIT Madras Nirmaan pre-incubated startup developing flexible computer vision solutions for dimensional inspection and defect detection in precision manufacturing."
    />
    <meta
      property="og:title"
      content="IGDD-AI | Intelligent Inspection Solutions for Manufacturing"
    />
    <meta
      property="og:description"
      content="Software-first computer vision platform for high-mix manufacturers."
    />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --background: #ffffff;
        --foreground: #0f172a;
        --card: #ffffff;
        --card-foreground: #0f172a;
        --muted: #f8fafc;
        --muted-foreground: #64748b;
        --primary: #1e293b;
        --primary-foreground: #f8fafc;
        --accent: #f1f5f9;
        --border: #e2e8f0;
        --input: #e2e8f0;
        --radius: 0.625rem;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI",
          Roboto, sans-serif;
        background-color: var(--background);
        color: var(--foreground);
        line-height: 1.6;
      }

      .container {
        max-width: 72rem;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* Header */
      header {
        border-bottom: 1px solid var(--border);
      }

      header .container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 1.25rem;
        padding-bottom: 1.25rem;
      }

      .brand {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
      }

      .brand-name {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -0.025em;
      }

      .brand-tag {
        display: none;
        font-size: 0.75rem;
        color: var(--muted-foreground);
      }

      @media (min-width: 640px) {
        .brand-tag {
          display: inline;
        }
      }

      nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }

      nav a {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--muted-foreground);
        text-decoration: none;
        transition: color 0.2s;
      }

      nav a:hover {
        color: var(--foreground);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.5rem 1rem;
        border-radius: calc(var(--radius) - 2px);
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: background-color 0.2s;
        border: none;
        cursor: pointer;
      }

      .btn-primary {
        background-color: var(--primary);
        color: var(--primary-foreground);
      }

      .btn-primary:hover {
        background-color: #334155;
      }

      .btn-secondary {
        background-color: var(--card);
        color: var(--foreground);
        border: 1px solid var(--input);
      }

      .btn-secondary:hover {
        background-color: var(--accent);
      }

      .btn-lg {
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
      }

      /* Hero */
      .hero {
        position: relative;
        overflow: hidden;
        padding: 5rem 0 6rem;
        text-align: center;
      }

      @media (min-width: 640px) {
        .hero {
          padding: 7rem 0 8rem;
        }
      }

      .hero h1 {
        font-size: 2.25rem;
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.1;
      }

      @media (min-width: 640px) {
        .hero h1 {
          font-size: 3.75rem;
        }
      }

      .hero p {
        max-width: 42rem;
        margin: 1.5rem auto 0;
        font-size: 1.125rem;
        color: var(--muted-foreground);
      }

      @media (min-width: 640px) {
        .hero p {
          font-size: 1.25rem;
        }
      }

      .hero-actions {
        margin-top: 2.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
      }

      @media (min-width: 640px) {
        .hero-actions {
          flex-direction: row;
        }
      }

      /* Sections */
      .section-muted {
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        background-color: var(--muted);
      }

      .section {
        padding: 5rem 0;
      }

      .section h2 {
        font-size: 1.875rem;
        font-weight: 700;
        letter-spacing: -0.025em;
      }

      @media (min-width: 640px) {
        .section h2 {
          font-size: 2.25rem;
        }
      }

      .section h3 {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--card-foreground);
      }

      .text-muted {
        color: var(--muted-foreground);
      }

      .text-center {
        text-align: center;
      }

      .max-w-2xl {
        max-width: 42rem;
      }

      .mx-auto {
        margin-left: auto;
        margin-right: auto;
      }

      .mt-4 {
        margin-top: 1rem;
      }

      .mt-5 {
        margin-top: 1.25rem;
      }

      .mt-8 {
        margin-top: 2rem;
      }

      .mt-10 {
        margin-top: 2.5rem;
      }

      .mt-14 {
        margin-top: 3.5rem;
      }

      /* Cards */
      .cards-grid {
        display: grid;
        gap: 1.5rem;
        margin-top: 3.5rem;
      }

      @media (min-width: 640px) {
        .cards-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (min-width: 1024px) {
        .cards-grid {
          grid-template-columns: repeat(3, 1fr);
        }
      }

      .card {
        border: 1px solid var(--border);
        background-color: var(--card);
        border-radius: calc(var(--radius) + 4px);
        padding: 1.5rem;
        box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        transition: box-shadow 0.2s;
      }

      .card:hover {
        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1),
          0 2px 4px -2px rgb(0 0 0 / 0.1);
      }

      .card p {
        margin-top: 0.5rem;
        color: var(--muted-foreground);
      }

      /* CTA */
      .cta-card {
        border: 1px solid var(--border);
        background-color: var(--card);
        border-radius: 1rem;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
      }

      @media (min-width: 640px) {
        .cta-card {
          padding: 3rem;
        }
      }

      /* Footer */
      footer {
        border-top: 1px solid var(--border);
        padding: 2rem 0;
      }

      footer .container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      @media (min-width: 640px) {
        footer .container {
          flex-direction: row;
        }
      }

      footer p,
      footer a {
        font-size: 0.875rem;
        color: var(--muted-foreground);
        text-decoration: none;
      }

      footer a:hover {
        color: var(--foreground);
      }

      .footer-links {
        display: flex;
        gap: 1.5rem;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <div class="brand">
          <span class="brand-name">IGDD-AI</span>
          <span class="brand-tag">IIT Madras Nirmaan Pre-incubated</span>
        </div>
        <nav>
          <a href="#about">About</a>
          <a href="#platform">Platform</a>
          <a href="mailto:hello@igdd.ai" class="btn btn-primary">Get in touch</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container">
          <h1>Smarter inspection for precision manufacturing</h1>
          <p>
            IGDD-AI builds flexible computer vision solutions that digitize
            dimensional inspection and defect detection—so high-mix
            manufacturers can improve quality, traceability, and efficiency
            without heavy hardware lock-in.
          </p>
          <div class="hero-actions">
            <a href="#platform" class="btn btn-primary btn-lg"
              >Explore the platform</a
            >
            <a href="#about" class="btn btn-secondary btn-lg">Learn about us</a>
          </div>
        </div>
      </section>

      <section id="about" class="section section-muted">
        <div class="container">
          <div class="max-w-2xl">
            <h2>Our mission</h2>
            <p class="text-muted mt-5" style="font-size: 1.125rem">
              We are making digital inspection more accessible for small and
              medium-sized manufacturers through software-first, scalable
              solutions. By combining computer vision with practical production
              know-how, we help teams move from manual checks to reliable,
              traceable digital workflows.
            </p>
          </div>
        </div>
      </section>

      <section id="platform" class="section">
        <div class="container">
          <h2 class="text-center">What we are building</h2>
          <p
            class="text-muted text-center mx-auto mt-4"
            style="font-size: 1.125rem; max-width: 42rem"
          >
            A flexible vision platform designed around real production
            environments.
          </p>

          <div class="cards-grid">
            <div class="card">
              <h3>Dimensional inspection</h3>
              <p>
                Capture precise measurements from images and validate tolerances
                automatically.
              </p>
            </div>
            <div class="card">
              <h3>Defect detection</h3>
              <p>
                Train and deploy vision models that spot anomalies on the line
                in real time.
              </p>
            </div>
            <div class="card">
              <h3>High-mix flexibility</h3>
              <p>
                Switch between parts, batches, and product families without
                re-engineering the setup.
              </p>
            </div>
            <div class="card">
              <h3>Traceability</h3>
              <p>
                Keep a digital record of every inspection result for audits and
                continuous improvement.
              </p>
            </div>
            <div class="card">
              <h3>Operational efficiency</h3>
              <p>
                Reduce rework, cut inspection time, and free up operators for
                higher-value work.
              </p>
            </div>
            <div class="card">
              <h3>Industry collaboration</h3>
              <p>
                We co-develop with manufacturers to ensure our technology solves
                real shop-floor problems.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="section section-muted">
        <div class="container">
          <div class="cta-card">
            <h2>Partner with us</h2>
            <p
              class="text-muted mx-auto mt-4"
              style="max-width: 36rem; font-size: 1rem"
            >
              We work closely with manufacturers and industry partners to
              validate market needs and build practical inspection
              technologies. If you are solving quality challenges on the shop
              floor, we would love to hear from you.
            </p>
            <a
              href="mailto:hello@igdd.ai"
              class="btn btn-primary btn-lg mt-8"
              >Contact IGDD-AI</a
            >
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="container">
        <p>
          &copy; <span id="year"></span> IGDD-AI. IIT Madras Nirmaan
          Pre-incubated Startup.
        </p>
        <div class="footer-links">
          <a href="mailto:hello@igdd.ai">hello@igdd.ai</a>
          <span>IIT Madras</span>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById("year").textContent = new Date().getFullYear();
    </script>
  </body>
</html>
